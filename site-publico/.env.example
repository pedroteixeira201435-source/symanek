# Copy to .env.local and fill in.
#   mock     -> no backend, forms resolve locally (demo)
#   supabase -> live backend via the shared Supabase project
NEXT_PUBLIC_API_MODE=supabase

# Local stack (supabase start):  http://127.0.0.1:54321
# Cloud project:                 https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (NOT NEXT_PUBLIC). Approval-letter generation + signed downloads.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
